}

@media (min-width:50.25rem) {
  .c27 {
    margin-top: 4rem;
  }
}

@media (min-width:50.25rem) {

}

@media (min-width:50.25rem) {
  .c63 {
    padding-right: unset;
    padding-left: unset;
    -webkit-align-items: unset;
    -webkit-box-align: unset;
    -ms-flex-align: unset;
    align-items: unset;
  }
}

@media (prefers-color-scheme:dark) {
  .c65:focus-visible::after {
    border-color: #ffffff;
  }
}

@media (min-width:32.25rem) {
  .c66 {
    font-size: 3rem;
  }
}

@media (prefers-color-scheme:dark) {
  .c66 {
    color: #ffffff;
  }
}

@media (min-width:32.25rem) {
  .c62 {
    padding: 2rem 2rem;
  }
}

@media (prefers-color-scheme:dark) {
  .c62 {
    border-top: solid #44aeff 0.15rem;
    background-color: #050d1b;
  }
}

@media (prefers-color-scheme:dark) {
  .c33 {
    box-shadow: 0.44rem 0.44rem 1rem 0 #00000000;
  }
}

@media (prefers-color-scheme:dark) {
  .c33:not(:disabled):focus,
  .c33:not(:disabled):focus-within,
  .c33:not(:disabled):active,
  .c33:not(:disabled):hover {
    box-shadow: 0.2rem 0.2rem 0.5rem 0 #00000000;
  }
}

